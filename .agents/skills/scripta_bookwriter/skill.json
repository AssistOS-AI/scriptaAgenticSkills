{
  "title": "SCRIPTA BookWriter",
  "family": "anthropic",
  "summary": "Combines chapter drafts into export-ready manuscript artifacts, single-file HTML reader editions, and QA publication mirrors.",
  "aliases": [
    "scripta_bookwriter",
    "scripta-bookwriter"
  ],
  "dependsOn": [
    "scripta_chapgen"
  ],
  "outputs": [
    "<workspace>/phase8-exports/manuscript.book.iter-*.md",
    "<workspace>/phase8-exports/edition-en.reader.iter-*.html",
    "<workspace>/phase8-exports/translation-source.bundle.iter-*.md",
    "<workspace>/phase8-exports/editions.bundle.iter-*.md"
  ],
  "entrypoints": [
    "SKILL.md",
    "skill.mjs"
  ],
  "selfContained": true
}
